DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Seed 8: Canva Publisher Receiver (PAT + rate limit + storage) ──────────
# AURA_PAT_PEPPER — 32+ char random pepper used in SHA-256(secret ‖ PEPPER).
# Rotating this env invalidates ALL active external tokens.
AURA_PAT_PEPPER=""

# Upstash Redis — 3-axis rate limiter (fallback: in-memory, dev only)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional Vercel KV-compatible fallback. Configure this complete pair only;
# rate limiters never mix a URL from one pair with a token from the other.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
# Set RL_FAIL_MODE=close to reject requests when Upstash is unreachable.
# Default (unset or "open") is fail-open per Seed 8 R6.
RL_FAIL_MODE=""

# Supabase client-direct share pages and Storage.
# Public keys are browser-safe and required by static /s and /share shells,
# plus the Shadow Alliance Realtime play board.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only Storage writes/deletes. Never expose this as NEXT_PUBLIC_*.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# One-time legacy media migration only. Required if old Vercel Blob URLs must be copied.
BLOB_READ_WRITE_TOKEN=""

# Tier gating (MVP before User.tier column lands)
# TIER_MODE=pro|free — global override for QA/local testing
TIER_MODE=""
# Comma-separated user IDs to treat as Free tier (dual-defense R7)
FREE_USER_IDS=""

# Absolute base URL used when composing response `url` for Canva toast
NEXT_PUBLIC_APP_BASE_URL="https://aura-board.com"

# Canva Connect API (server-only except the public app base URL above).
CANVA_CLIENT_ID=""
CANVA_CLIENT_SECRET=""
CANVA_REDIRECT_URI="https://aura-board.com/api/auth/canva/callback"

# Server-only AES-256-GCM key for Canva access/refresh tokens and PKCE data.
# Use a dedicated random value in production. AUTH_SECRET is used as fallback.
CANVA_TOKEN_ENCRYPTION_KEY=""

# Canva functional-review login. Server-only; no public password signup exists.
# Generate a password/hash pair with: npm run canva:reviewer:generate
CANVA_REVIEWER_EMAIL=""
CANVA_REVIEWER_NAME="Canva Integration Reviewer"
CANVA_REVIEWER_PASSWORD_HASH=""
