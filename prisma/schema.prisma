// A student-submitted marquee text or image waiting for the submitting
// student's classroom teacher to moderate it.  The publication row below is
// deliberately separate: its unique day is the global at-most-one gate.
enum DailyBannerSubmissionKind {
  text
  image
}

enum DailyBannerSubmissionStatus {
  pending
  approved
  rejected
}

model DailyBannerSubmission {
  id String @id @default(cuid())

  studentId   String
  classroomId String

  // Calendar day in Asia/Seoul. The API accepts YYYY-MM-DD and stores it as
  // a PostgreSQL DATE so server timezone changes cannot move the banner.
  targetDay DateTime @db.Date

  kind     DailyBannerSubmissionKind
  text     String?                   @db.Text
  imageUrl String?

  status          DailyBannerSubmissionStatus @default(pending)
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?                     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student     Student                 @relation("DailyBannerSubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  classroom   Classroom               @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  reviewedBy  User?                   @relation("DailyBannerReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  publication DailyBannerPublication?

  @@unique([id, classroomId, targetDay])
  @@index([targetDay, status, createdAt])
  @@index([classroomId, targetDay, status])
  @@index([studentId, targetDay, createdAt])
}

// One visible banner per classroom and KST calendar day. Approval inserts this
// row in the same transaction that marks the submission approved; the compound
// unique constraint makes concurrent approvals within a classroom race-safe.
model DailyBannerPublication {
  id String @id @default(cuid())

  classroomId  String
  day          DateTime @db.Date
  submissionId String   @unique
  approvedById String
  publishedAt  DateTime @default(now())

  submission DailyBannerSubmission @relation(fields: [submissionId, classroomId, day], references: [id, classroomId, targetDay], onDelete: Cascade)
  approvedBy User                  @relation("DailyBannerPublishedBy", fields: [approvedById], references: [id], onDelete: Cascade)

  @@unique([classroomId, day])
  @@unique([submissionId, classroomId, day])
  @@index([day])
}

model StudentWalkingDailyStat {
  id String @id

  studentId      String
  day            DateTime @db.Date
  steps          Int      @default(0)
  distanceMeters Float    @default(0)
  source         String   @default("health_connect")
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, day], map: "StudentWalkingDailyStat_studentId_day_key")
  @@index([day], map: "StudentWalkingDailyStat_day_idx")
  @@index([studentId, syncedAt], map: "StudentWalkingDailyStat_studentId_syncedAt_idx")
}

// Per-student read cursor and receipts for the in-app like/comment feed.
// This is intentionally separate from CardLike/CardComment because one event
// can notify more than one student when a card has multiple authors.
model StudentNotificationState {
  id String @id @default(cuid())

  studentId String @unique

  lastReadAt DateTime?

  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentNotificationReceipt {
  id String @id @default(cuid())

  studentId String

  notificationType String

  notificationId String

  readAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, notificationType, notificationId])
  @@index([studentId, readAt])
}

