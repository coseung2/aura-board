// parent-class-invite-v2 ??ParentLinkStatus lifecycle.

//   pending  ??(approve) ??active

//   pending  ??(reject | code_rotated | auto_expired) ??rejected

//   active   ??(teacher_revoked | classroom_deleted | year_end | parent_self_leave) ??revoked

// rejected/revoked are dead-end. See src/lib/parent-link-state.ts for the

// transition validator used by every state-changing endpoint.

enum ParentLinkStatus {
  pending

  active

  rejected

  revoked
}

// UI dropdown for teacher reject action exposes only the first 3 values.

// System-originated reject uses code_rotated | auto_expired | classroom_deleted.

enum ParentRejectedReason {
  wrong_child

  not_parent

  other

  code_rotated

  auto_expired

  classroom_deleted
}

// v1 had 3 revoked reasons; v2 adds 4 more (audit completeness ??system

// transitions that originate from pending??紐꾩툛jected ALSO get a matching

// revokedReason row for downstream reporting).

enum ParentRevokedReason {
  teacher_revoked

  year_end

  parent_self_leave

  rejected_by_teacher

  auto_expired_pending

  code_rotated

  classroom_deleted
}

model ParentChildLink {
