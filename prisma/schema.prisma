  finalScore   Int
  releasedAt   DateTime? // Classroom.gradebookReleasePolicy="teacher_manual" gate
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submission AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([releasedAt])
}

// тФАтФАтФАтФА DJ Board тАФ classroom role system тФАтФАтФАтФА
// эХЩъ╕Й ыВ┤ эХЩьГЭьЧРъ▓М "DJ"/"ьВмьДЬ"/"ьЭАэЦЙьЫР" ыУ▒ьЭШ ьЧнэХаьЭД ы╢АьЧмэХШъ│а, эХ┤ыЛ╣ ьЧнэХаьЭ┤
// эК╣ьаХ ы│┤ыУЬ ыаИьЭ┤ьХДьЫГьЧРьДЬ BoardMember(owner/editor) ъ╢МэХЬьЭД ьК╣ъ│ДэХШыПДыбЭ эХЬыЛд.
// ыН░ьЭ┤эД░ ьг╝ыПД ьДдъ│Д тАФ ьГИ ьЧнэХа ь╢Фъ░А = row insert, ь╜ФыУЬ ы│Аъ▓╜ ьЧЖьЭМ.

model ClassroomRoleDef {
