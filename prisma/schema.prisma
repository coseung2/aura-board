// Kordle (BC-2): built-in Wordle engine, scoped to a Board.
// Models live next to other gameplay (Vibe*) and reuse `Board` + `VibePlaySession`
// for the classroom/board shell. New tables are Kordle-specific so guessing
// state, validation feedback, and dictionary don't pollute Quiz/VibeProject.

enum KordleGameMode {
  CLASSIC
  DAILY
  TEACHER_CUSTOM
  LIVE_CLASS
}

enum KordlePuzzleStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSED
  ARCHIVED
}

enum KordleAttemptStatus {
  IN_PROGRESS
  WON
  LOST
  ABANDONED
}

model KordleGame {
  id         String         @id @default(cuid())
  // One Kordle engine per Board. When a teacher picks "놀이" with the
  // Kordle layout, we create the row here in the same transaction.
  boardId    String         @unique
  board      Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title      String?
  // 5 is the classic Wordle length; 6/7 reserved for future.
  wordLength Int            @default(5)
  maxGuesses Int            @default(6)
  mode       KordleGameMode @default(CLASSIC)
  // Locale-tagged: ko-KR / en-US. Affects dictionary + jamo rules.
  locale     String         @default("ko-KR")
  puzzles    KordlePuzzle[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model KordlePuzzle {
  id                String             @id @default(cuid())
  gameId            String
  game              KordleGame         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  // The solution word. KordleWord.locale must match KordleGame.locale.
  solutionWordId    String
  solutionWord      KordleWord         @relation(fields: [solutionWordId], references: [id])
  status            KordlePuzzleStatus @default(DRAFT)
  // When the puzzle goes live (DAILY mode uses startsAt; LIVE_CLASS uses live
  // toggles). Null until scheduled.
  startsAt          DateTime?
  endsAt            DateTime?
  currentGuessIndex Int                @default(1)
  // Optional deterministic seed so two classrooms get the same word for the
  // same date without sharing a row.
  seed              String?
  attempts          KordleAttempt[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([gameId, startsAt])
  @@index([status, startsAt])
}

model KordleAttempt {
  id                String              @id @default(cuid())
  puzzleId          String
  puzzle            KordlePuzzle        @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  // Nullable so a teacher can demo without owning a VibePlaySession.
  // Normal students get one VibePlaySession per play (per existing
  // VibeProject lifecycle); Kordle keys off that.
  vibePlaySessionId String?
  vibePlaySession   VibePlaySession?    @relation(fields: [vibePlaySessionId], references: [id], onDelete: SetNull)
  // Direct student FK for cases without a VibePlaySession (e.g. anonymous
  // share-link play). Either studentId or vibePlaySessionId must be set
  // — enforced in the server action.
  studentId         String?
  student           Student?            @relation(fields: [studentId], references: [id], onDelete: SetNull)
  teacherUserId     String?
  teacherUser       User?               @relation("TeacherKordleAttempts", fields: [teacherUserId], references: [id], onDelete: SetNull)
  status            KordleAttemptStatus @default(IN_PROGRESS)
  // Which guess (1-indexed) won; null until status=WON.
  solvedAtGuess     Int?
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  guesses           KordleGuess[]

  @@index([puzzleId, status])
  @@index([studentId, startedAt])
  @@index([teacherUserId, startedAt])
}

model KordleGuess {
  id         String        @id @default(cuid())
  attemptId  String
  attempt    KordleAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  // 1-indexed guess order within the attempt.
  guessIndex Int
  // Raw text the student entered (normalized server-side before compare).
  guess      String
  // Per-letter feedback: [{char, state: 'correct'|'present'|'absent'}]
  // Serialized as JSON to keep the schema portable and to avoid a
  // join table for 5-7 char rows.
  feedback   Json
  isCorrect  Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@unique([attemptId, guessIndex])
}

model KordleWord {
  id         String         @id @default(cuid())
  // Surface form (e.g. "학교" or "apple").
  text       String
  // Normalized form used for validation: lowercased + jamo-decomposed for
  // Korean. The engine compares normalized-to-normalized.
  normalized String
  length     Int
  locale     String         @default("ko-KR")
  // Optional CEFR/grade bucket for unit-scoping.
  difficulty Int?
  // Whether this word can be used as a *solution*. The dictionary table
  // can also hold isAllowed-only words (valid guesses, not solutions).
  isSolution Boolean        @default(true)
  isAllowed  Boolean        @default(true)
  // Optional curriculum unit tag (free-form for now; future: a Unit table).
  unitTag    String?
  puzzles    KordlePuzzle[]

  @@unique([locale, normalized])
  @@index([locale, length, isSolution])
  @@index([locale, unitTag])
}

// ===== Avatar customization MVP (2026-07-02) =====
//
// Self-contained character layer. The wallet source of truth stays
// StudentAccount.balance + Transaction; avatar purchases reuse the same
// Transaction table with `type = "avatar_purchase"`. Art is intentionally
// nullable: items can be code-seeded with `imageUrl: null` and a metadata
// JSON describing fallback colors/shapes, then upgraded later.

model AvatarItem {
  id           String   @id @default(cuid())
  // null = system/default catalog item available to every classroom.
  // Non-null = classroom-scoped item added by the teacher.
  classroomId  String?
  // Stable code within a (classroomId) scope. System items use a global
  // key (e.g. "default-skin-01"); classroom items prefix with classroomId.
  key          String
  name         String
  description  String?
  // "skin" | "background" | "hair" | "outfit" | "accessory" | "pet"
  category     String
  // Equipment slot key (e.g. "skin", "background"). Null = not wearable.
  slot         String?
  // "common" | "rare" | "epic" | "legendary"
  rarity       String   @default("common")
  price        Int      @default(0)
  imageUrl     String?
  thumbnailUrl String?
  metadata     Json?
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  classroom    Classroom?            @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  inventory    AvatarInventoryItem[]
  loadoutSlots AvatarLoadoutItem[]
  purchases    AvatarPurchase[]

  // System items (classroomId IS NULL) share the (classroomId, key) pair
  // where classroomId is NULL — distinct per row in both SQLite and
  // Postgres, so app-level uniqueness gates duplicates.
  @@unique([classroomId, key])
  @@index([classroomId, archived])
  @@index([category, archived])
}

model AvatarInventoryItem {
  id          String   @id @default(cuid())
  studentId   String
  itemId      String
  // "purchase" | "reward" | "grant"
  acquiredVia String   @default("purchase")
  // Free-form reference (transaction id, reading log id, ...). Nullable
  // for manual grants.
  sourceRef   String?
  acquiredAt  DateTime @default(now())

  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item    AvatarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([studentId, itemId])
  @@index([studentId])
}

model AvatarLoadout {
  id        String   @id @default(cuid())
  studentId String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  student Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items   AvatarLoadoutItem[]
}

model AvatarLoadoutItem {
  id        String  @id @default(cuid())
  loadoutId String
  // Slot key (e.g. "skin", "background"). Unique per loadout.
  slot      String
  // Nullable so an unequip can clear the row in one update.
  itemId    String?

  loadout AvatarLoadout @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  item    AvatarItem?   @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([loadoutId, slot])
  @@index([loadoutId])
}

model AvatarPurchase {
  id            String   @id @default(cuid())
  studentId     String
  itemId        String
  unitPrice     Int
  // "succeeded" | "failed"
  status        String   @default("succeeded")
  // @unique: each Transaction is linked to at most one AvatarPurchase (1:1).
  transactionId String?  @unique
  failureReason String?
  createdAt     DateTime @default(now())

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  item        AvatarItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([itemId])
}

model AvatarRewardConfig {
  classroomId                String @id
  // Wallet reward per reading score point (e.g. 10 won per point).
  readingRewardPerPoint      Int    @default(5)
  // Minimum aiScore required to trigger a payout (0..10 evaluator range).
  readingMinScoreForPayout   Int    @default(5)
  readingDailyRewardCap      Int    @default(10)
  readingWeeklyRewardCap     Int    @default(20)
  commentRewardAmount        Int    @default(5)
  commentDailyRewardCap      Int    @default(10)
  commentWeeklyRewardCap     Int    @default(30)
  commentMinMeaningfulLength Int    @default(4)
  // Walking activity reward policy seeds. Values <= 0 disable the
  // corresponding walking reward without requiring another migration.
  walkingRewardStepThreshold Int    @default(5000)
  walkingRewardAmount        Int    @default(10)
  walkingDailyUnitCap        Int    @default(4)
  walkingWeeklyRewardDayCap  Int    @default(5)
  walkingWeeklyTier1Steps    Int    @default(25000)
  walkingWeeklyTier1Amount   Int    @default(20)
  walkingWeeklyTier2Steps    Int    @default(50000)
  walkingWeeklyTier2Amount   Int    @default(40)
  walkingWeeklyTier3Steps    Int    @default(75000)
  walkingWeeklyTier3Amount   Int    @default(100)
  assignmentRewardAmount     Int    @default(20)
  // Zero means unlimited submissions for the assignment reward.
  assignmentDailyRewardCap   Int    @default(0)
  assignmentWeeklyRewardCap  Int    @default(0)
  rewardBuffCapBps           Int    @default(2000)

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
}

model AvatarGalleryEntry {
  id          String    @id @default(cuid())
  classroomId String
  studentId   String
  // When the student opted in to appear in the town gallery.
  visibleFrom DateTime  @default(now())
  // Soft-revoke timestamp; null = currently visible.
  revokedAt   DateTime?

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([classroomId, revokedAt])
}

// ===== Speed Game (스피드게임, 2026-07-06) =====
//
// Board(layout="speed-game") 보드 1개당 SpeedGame 1개. 라운드별 키워드 +
// guesser 슬롯 + 학생 답/점수. 모둠은 기존 board default groups를 그대로
// 재사용(별도 team 테이블 없음). status/answerMode 같은 enum은 String으로
// 둬서 추후 케이스 추가 시 마이그레이션 비용을 0으로 유지.
//
// Keyword/answer normalization은 src/lib/speed-game/score.ts의 헬퍼를
// 단일 출처로 사용한다(공백 제거 + lowercase, trim된 exact compare).

model SpeedGameWordSet {
  id        String   @id @default(cuid())
  // null = 시스템 기본 세트(전 교사 노출, 편집/삭제 불가).
  // null이 아니면 해당 teacher 소유.
  userId    String?
  // UI/검색용 stable key. 시스템은 "system-<topic>" 컨벤션.
  key       String
  name      String
  // "ko" | "en" — 표기/정규화에 영향. UI 필터링에도 사용.
  locale    String   @default("ko")
  // 콤마로 join된 키워드. 사용 시 split/normalize.
  // 저장 시 trim/dedupe 1..80자 1..100개 (서버 검증).
  keywords  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 시스템(userId NULL) 세트는 key 충돌 불가, 사용자 세트는 (userId, key) 충돌 불가.
  // NULL은 NULL 끼리는 unique 비교에서 distinct로 취급되므로 시스템/사용자
  // 세트가 같은 key를 가져도 OK.
  @@unique([userId, key])
  @@index([userId])
}

model SpeedGame {
  id              String    @id @default(cuid())
  boardId         String    @unique
  board           Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  // "lobby" | "running" | "finished"
  status          String    @default("lobby")
  // 현재 활성 라운드 index. -1이면 아직 시작 전.
  roundIndex      Int       @default(-1)
  // "exact" | "teacher-approval"
  // - exact: 서버에서 trim/normalize로 즉시 정답 판정
  // - normalize-space: 모든 공백을 제거하고 비교
  // - teacher-approval: 교사가 PATCH로 accept/reject
  answerMode      String    @default("exact")
  // 점수 계산 기본값. 생성 모달에서 보드별로 조정 가능.
  baseScore       Int       @default(1000)
  minScore        Int       @default(0)
  // 보너스 점수 랭크 컷오프(1~3등). 0 = 보너스 없음. 항상 정확히 3개 값.
  bonusRanks      String    @default("300,200,100")
  // 라운드 시작 시의 ms 단위 시간 한도(힌트/타이머용). 0 = 무제한.
  timeLimitMs     Int       @default(0)
  // 활성 라운드의 startedAt. SSE가 흘려보내는 clock anchor.
  activeStartedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rounds  SpeedGameRound[]
  answers SpeedGameAnswer[]

  @@index([status])
}

model SpeedGameRound {
  id                String    @id @default(cuid())
  gameId            String
  game              SpeedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  // 0-indexed 라운드 순서. 같은 게임 내에서 unique.
  order             Int
  // 표시 키워드(원문). 화면에 그대로 노출.
  keyword           String
  // 정규화된 키워드(공백 제거 + lowercase). exact 판정/검증용.
  keywordNormalized String
  // 1..4 슬롯. (order % 4) + 1로 자동 계산, 오버라이드 허용.
  guesserSlot       Int       @default(1)
  // 라운드 시작 시각. null이면 아직 시작 안 함.
  startedAt         DateTime?
  // 라운드 종료(다음 라운드 시작 또는 게임 종료) 시각.
  endedAt           DateTime?
  createdAt         DateTime  @default(now())

  answers SpeedGameAnswer[]

  @@unique([gameId, order])
  @@index([gameId])
}

model SpeedGameAnswer {
  id          String         @id @default(cuid())
  roundId     String
  round       SpeedGameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  // 보드 default group ID (String, FK 없음). 런타임 검증은 join으로.
  groupId     String
  studentId   String
  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // 정답/오답. teacher-approval 모드에서 교사가 false로 확정 가능.
  correct     Boolean        @default(false)
  // 0 = 오답, 그 외 = 점수(보너스 포함 가능).
  score       Int            @default(0)
  // "pending" | "accepted" | "rejected" (teacher-approval 모드에서만 사용)
  // exact 모드에서는 accept 즉시 "accepted"로 박힌다.
  approval    String         @default("pending")
  // 학생이 입력한 원문(공백 유지). UI 디버그/감사용.
  rawText     String
  // 라운드 시작 후 답을 제출한 시점까지의 경과 ms. 0 = 시작 전 입력.
  elapsedMs   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  speedGame   SpeedGame?     @relation(fields: [speedGameId], references: [id])
  speedGameId String?

  // 한 라운드에서 한 모둠당 1개의 답만 허용. 후속 시도는 update.
  @@unique([roundId, groupId])
  @@index([roundId])
  @@index([studentId])
  @@index([groupId])
}
