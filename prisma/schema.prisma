// ???????? Canva Connect API token store ????????

// Canva as an IdP ??teachers OAuth into their Canva account so we can call

// Canva's REST API on their behalf (e.g. list designs, export PDF). Storing

// tokens in DB (not in-memory Map) so Vercel Function cold starts don't

// silently log the teacher out between requests.

//

// `pkceVerifier` holds the transient verifier during the authorize ??callback

// round-trip. It's cleared on successful exchangeCode. For a long-idle user

// whose refresh token has also expired we simply require re-authorize.

model CanvaConnectAccount {
  userId String @id

  canvaUserId String?

  canvaTeamId String?

  accessToken String?

  refreshToken String?

  expiresAt DateTime?

  pkceVerifier String?

  updatedAt DateTime @updatedAt

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id String @id @default(cuid())

  userId String

  type String

  provider String

  providerAccountId String

  refresh_token String?

  access_token String?

  expires_at Int?

  token_type String?

  scope String?

  id_token String?

  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id String @id @default(cuid())

  sessionToken String @unique

  userId String

  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

