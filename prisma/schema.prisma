// Yellow card system (2026-07-08)
// 교사가 (또는 권한을 가진 학생이) 한 학생에게 노란 카드를 부여한다.
// 같은 날 두 번째 노란 카드를 받은 학생은 자동으로 오늘의 청소 당번에
// 등록된다 (CleaningDuty row 1개를 같은 트랜잭션으로 생성).
// 일 단위 카운트는 givenAt 의 UTC 날짜로 한다.
model YellowCard {
  id               String   @id @default(cuid())
  classroomId      String
  studentId        String
  // 부여한 사람: 학생 (검사 역할) 또는 교사. 둘 중 하나는 반드시 존재.
  givenByStudentId String?
  givenByUserId    String?
  reason           String   @db.Text
  givenAt          DateTime @default(now())
  createdAt        DateTime @default(now())

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     Student   @relation("YellowCardStudent", fields: [studentId], references: [id], onDelete: Cascade)
  givenBy     Student?  @relation("YellowCardGivenBy", fields: [givenByStudentId], references: [id], onDelete: SetNull)
  givenByUser User?     @relation("YellowCardGivenByUser", fields: [givenByUserId], references: [id], onDelete: SetNull)

  @@index([classroomId, givenAt])
  @@index([classroomId, studentId, givenAt])
  @@index([studentId, givenAt])
}

// Cleaning duty (청소 당번) (2026-07-08)
// 오늘의 청소 당번 명단. 같은 학생이 같은 날 여러 번 추가되지 않도록
// (classroomId, studentId, dutyDate) unique 로 가드한다. POST 는
// upsert 의미론을 사용한다 (이미 있으면 그대로 유지).
model CleaningDuty {
  id                  String   @id @default(cuid())
  classroomId         String
  studentId           String
  // 청소 당번 날짜. UTC 자정 (parseDateOrNull 결과) 그대로 저장.
  dutyDate            DateTime
  // "manual" = 교사가 직접 지정, "yellow_card" = 노란 카드 자동 부여.
  source              String   @default("manual")
  assignedByStudentId String?
  assignedByUserId    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  classroom      Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student        Student   @relation("CleaningDutyStudent", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy     Student?  @relation("CleaningDutyAssignedBy", fields: [assignedByStudentId], references: [id], onDelete: SetNull)
  assignedByUser User?     @relation("CleaningDutyAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([classroomId, studentId, dutyDate])
  @@index([classroomId, dutyDate])
  @@index([studentId, dutyDate])
}

