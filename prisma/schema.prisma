// ===== Creature system v1 =====
//
// Static lines, stages, products, and catalog odds live in
// src/lib/creatures/catalog.ts. These rows only persist a student's
// server-authoritative creature state, progress audit, and item inventory.

model StudentCreature {
  id String @id @default(cuid())

  studentId   String
  classroomId String

  lineKey         String
  stage           String  @default("egg")
  isActive        Boolean @default(true)
  isFeatured      Boolean @default(false)
  progressPoints  Int     @default(0)
  rulesVersion    String  @default("creature-rules-v1")
  catalogRevision String
  purchaseMode    String
  oddsSnapshot    Json?

  originSourceType String
  originSourceRef  String

  purchaseTransactionId String @unique

  incubatingStartedAt DateTime  @default(now())
  hatchedAt           DateTime?
  juvenileAt          DateTime?
  evolvedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  student             Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom           Classroom               @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  purchaseTransaction Transaction             @relation("CreatureEggPurchase", fields: [purchaseTransactionId], references: [id], onDelete: Restrict)
  progressEvents      CreatureProgressEvent[]
  itemUses            CreatureItemUse[]

  @@unique([originSourceType, originSourceRef])
  @@index([studentId, isActive])
  @@index([studentId, lineKey])
  @@index([classroomId])
}

model StudentSlime {
  id String @id @default(cuid())

  studentId   String
  classroomId String
  color       String
  // Only equipped slimes contribute their server-calculated reward effect.
  isEquipped Boolean @default(true)
  // Exactly one owned slime is shown as the student's representative.
  isRepresentative Boolean @default(false)
  // Passive slime growth is an effective wall-clock timer.  The service
  // settles growthSeconds using growthAppliedSpeedBps before changing either
  // the equipped state or the applied rate.
  growthStage           Int      @default(1)
  growthSeconds         Int      @default(0)
  growthRemainderBps    Int      @default(0)
  growthLastSettledAt   DateTime @default(now())
  growthAppliedSpeedBps Int      @default(0)
  // Shop cosmetics are assigned per owned slime. Each category is kept to one
  // item by the slime equipment service.
  equippedItemKeys String[] @default([])

  purchaseTransactionId String @unique

  createdAt DateTime @default(now())

  student             Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom           Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  purchaseTransaction Transaction  @relation("SlimePurchase", fields: [purchaseTransactionId], references: [id], onDelete: Restrict)

  @@unique([studentId, color])
  @@index([studentId, createdAt])
  @@index([studentId, isRepresentative])
  @@index([classroomId])
}

model CreatureProgressEvent {
  id String @id @default(cuid())

  studentCreatureId String
  studentId         String
  classroomId       String

  sourceType     String
  sourceRef      String
  idempotencyKey String    @unique
  rulesVersion   String
  currencyAmount Int
  progressDelta  Int
  progressBefore Int
  progressAfter  Int
  stageBefore    String
  stageAfter     String
  appliedAt      DateTime  @default(now())
  reversedAt     DateTime?

  creature  StudentCreature @relation(fields: [studentCreatureId], references: [id], onDelete: Cascade)
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([studentId, sourceType, sourceRef])
  @@index([studentCreatureId, appliedAt])
  @@index([classroomId])
}

model StudentCreatureItem {
  id String @id @default(cuid())

  studentId   String
