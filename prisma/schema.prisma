// SectionBreakoutConfig ??one row per Section that has breakout mode enabled.

// sectionId is unique so re-enabling/re-configuring is a single upsert.

// joinMode is currently fixed to "student_select" (server only accepts that

// value) ??stored as a string so future modes ("teacher_assign") don't need

// a migration.

model SectionBreakoutConfig {
  id String @id @default(cuid())

  sectionId String @unique

  groupCount Int @default(4)

  groupCapacity Int? // null = unlimited

  joinMode String @default("student_select")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// SectionBreakoutGroup ??a single group within a section's breakout. order

// is the display slot (1-based in API responses, 0-based in the DB to match

// Section.order). @@unique([sectionId, order]) prevents the teacher from

// accidentally creating two groups at the same slot via the API.

model SectionBreakoutGroup {
  id String @id @default(cuid())

  sectionId String

  name String

  order Int @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  members SectionBreakoutMembership[]

  cards Card[] @relation("SectionBreakoutGroupCards")

  @@unique([sectionId, order])
  @@index([sectionId])
}

// SectionBreakoutMembership ??a Student's pick within a section breakout.

// @@unique([sectionId, studentId]) enforces "one group per student per

// section" so a re-pick is a single upsert.

model SectionBreakoutMembership {
  id String @id @default(cuid())

  sectionId String

  groupId String

  studentId String

  joinedAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  group SectionBreakoutGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@index([groupId])
  @@index([studentId])
}

