// Aura-board тАФ Prisma schema
// DB: SQLite for local dev. To switch to Postgres:
//   1) change provider to "postgresql"
//   2) change DATABASE_URL to postgres://тАж
//   3) run `prisma db push --force-reset`
// Avoid SQLite-specific types (@db.*) so the schema stays portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  memberships            BoardMember[]
  cards                  Card[]
  submissions            Submission[]
  reviews                SubmissionReview[]
  accounts               Account[]
  sessions               Session[]
  classrooms             Classroom[]
  templatesOwned         BreakoutTemplate[]        @relation("TemplateOwner")
  issuedParentInvites    ParentInviteCode[]        @relation("TeacherInvite")
  canvaConnect           CanvaConnectAccount?
  // parent-class-invite-v2 тАФ issued codes + audit FKs into ParentChildLink
  classInvitesIssued     ClassInviteCode[]         @relation("ClassInviteIssued")
  approvedParentLinks    ParentChildLink[]         @relation("LinkApprovedBy")
  rejectedParentLinks    ParentChildLink[]         @relation("LinkRejectedBy")
  revokedParentLinks     ParentChildLink[]         @relation("LinkRevokedBy")
  // dj-board-queue тАФ teacher audit for role assignments
  roleAssignmentsGranted ClassroomRoleAssignment[] @relation("ClassroomRoleAssignedBy")
  // Teacher's own LLM API key (vibe-arcade + future AI features)
  llmKey                 TeacherLlmKey?
  // Billing (Toss Payments ьаХъ╕░ъ▓░ьаЬ тАФ Seed 14 scaffold, 2026-04-22)
  subscription           TeacherSubscription?
  paymentEvents          PaymentEvent[]
  boardResponses         BoardResponse[]           @relation("UserBoardResponses")
  // AI эПЙьЦ┤ (2026-04-24) тАФ ъ╡РьВмъ░А эХЩьГЭы│ДыбЬ ьГЭьД▒эХЬ эПЙьЦ┤ эЕНьКдэК╕
  aiFeedbacks            AiFeedback[]              @relation("TeacherAiFeedbacks")
  // OAuth as subject тАФ Aura companion teacher OAuth (2026-04-24)
  oauthAuthCodesAsUser   OAuthAuthCode[]           @relation("UserOAuthAuthCodes")
  oauthAccessTokensAsUser  OAuthAccessToken[]      @relation("UserOAuthAccessTokens")
  oauthRefreshTokensAsUser OAuthRefreshToken[]     @relation("UserOAuthRefreshTokens")
  // card-comments-likes (2026-04-26)
  cardComments             CardComment[]            @relation("UserCardComments")
  cardLikes                CardLike[]               @relation("UserCardLikes")
}

// тФАтФАтФАтФА Audit Log (Seed 14 security, 2026-04-22) тФАтФАтФАтФА
// ъ╢МэХЬ ьЮИыКФ эЦЙыПЩ(ьЧнэХа ы╢АьЧм, ы│┤ыУЬ ьВньаЬ, эЩШы╢И, ьЫ╣эЫЕ ь▓Шыжм, эЖаэБ░ эЪМьаД ыУ▒)ьЭШ
// ъ░РьВм ь╢ФьаБ. `actorType` + `actorId` ыбЬ ъ╡РьВм/эХЩьГЭ/ьЛЬьКдэЕЬ/ъ┤АыжмьЮР ъ╡мы╢Д.
// `metadata` JSON ьЧР ьЭ┤ьаД ьГБэГЬ┬╖ъ▓░ъ│╝ ыУ▒ ьГБьД╕ ь╗иэЕНьКдэК╕. `resourceType/Id` ыбЬ
// ыМАьГБ ьЛЭы│Д. ьВмъ│а ы░ЬьГЭ ьЛЬ createdAt ы▓ФьЬДыбЬ эГАьЮДыЭ╝ьЭ╕ ьЮмъ╡мьД▒.
model AuditEvent {
  id           String   @id @default(cuid())
  actorType    String // "teacher" | "student" | "system" | "admin"
  actorId      String? // nullable (system actions)
  action       String // "board.delete" | "role.grant" | "billing.refund" | "admin.rotate_tokens" | ...
  resourceType String? // "board" | "classroom" | "student" | "subscription" | ...
  resourceId   String?
  metadata     Json?
  ip           String? // extractIp + hashIp ъ▓░ъ│╝ (16ьЮР sha256 prefix)
  createdAt    DateTime @default(now())

  @@index([actorType, actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}

// тФАтФАтФАтФА Teacher LLM API Key (Seed 13 follow-up, 2026-04-22) тФАтФАтФАтФА
// ъ╡РьВмъ░А /docs/ai-setup эОШьЭ┤ьзАьЧРьДЬ ьЮЕыаеэХЬ Claude/OpenAI/Gemini API Key.
// ьДЬы▓Д AES-256-GCM ьХФэШ╕эЩФ эЫД DB ьаАьЮе. эХЩьГЭ эБ┤ыЭ╝ьЭ┤ьЦ╕эК╕ьЧРыКФ ьаИыМА ыВ┤ыадъ░АьзА ьХКъ│а
// ыкиыУа эШ╕ь╢ЬьЭА ьДЬы▓Д эФДыбЭьЛЬ(/api/vibe/sessions)ьЧРьДЬ ы│╡эШ╕эЩФ тЖТ ъ░Б ьВм APIыбЬ эПмьЫМыФй.
//
// 1 teacher = 1 key row (ьЮмьаАьЮе ьЛЬ upsertыбЬ ыНоьЦ┤ьУ░ъ╕░).
// verified/verifiedAt: ьаАьЮе ьЛЬ ъ░Б ьВм APIьЧР ьЮСьЭА эЕМьКдэК╕ эШ╕ь╢ЬьЭД ы│┤ыВ┤ ьД▒ъ│╡эЦИыКФьзА.
// lastError: 401/ъ▓░ьаЬ ьЛдэМи ыУ▒ьЭД UIьЧР эСЬьЛЬэХШъ╕░ ьЬДэХЬ ь╡Ьъ╖╝ ьЧРыЯм ыйФьЛЬьзА.
model TeacherLlmKey {
  userId     String    @id
  provider   String // "claude" | "openai" | "gemini" | "ollama"
  apiKeyEnc  String // base64(iv[12] || authTag[16] || ciphertext). ollamaый┤ ы╣И ым╕ьЮРьЧ┤ эЧИьЪй
  last4      String // ьЫРым╕ API KeyьЭШ ызИьзАызЙ 4ьЮР (UI эСЬьЛЬьЪй)
  // ollama ыбЬь╗м эЕМьКдэК╕ьЪй тАФ ыЛдые╕ providerыКФ null
  baseUrl    String?
  modelId    String?
  verified   Boolean   @default(false)
  verifiedAt DateTime?
  lastError  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// тФАтФАтФАтФА Billing / ьаХъ╕░ъ▓░ьаЬ (Seed 14 scaffold, 2026-04-22) тФАтФАтФАтФА
// ъ╡РьВм ъ│ДьаХ Free тЖФ Pro ъ╡мыПЕ ьГБэГЬ. 1 user = 1 subscription (userId PK).
// PGыКФ эЖаьКдэОШьЭ┤ыи╝ь╕а ы╣МызБэВд ы░йьЛЭьЭД ъ╕░ы│╕ьЬ╝ыбЬ эХШъ│а, provider эХДыУЬыбЬ ь╢ФэЫД
// эПмэК╕ьЫР ыУ▒ эЩХьЮеэХа ьИШ ьЮИъ▓М ыВиъ▓╝ыЛд. billingKeyыКФ ъ▓░ьаЬ ьЛЬ ьВмьЪйьЮР эЩХьЭ╕ ы╢ИэХДьЪФ тАФ
// ы░ШыУЬьЛЬ ьДЬы▓Д эФДыбЭьЛЬыбЬызМ ьВмьЪй, ьаИыМА эБ┤ыЭ╝ьЭ┤ьЦ╕эК╕ьЧР ыВ┤ыадъ░АьзА ьХКыКФыЛд.
model TeacherSubscription {
  userId             String    @id
  // "free" | "pro_monthly" | "pro_yearly"
  plan               String    @default("free")
  // "active" | "trial" | "past_due" | "canceled" | "paused"
  status             String    @default("active")
  pgProvider         String    @default("toss") // "toss" | "portone"
  pgCustomerKey      String?   @unique
  pgBillingKey       String?
  pgBillingKeyLast4  String?
  amount             Int       @default(0) // KRW per period
  currency           String    @default("KRW")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime? // ъ╡мыПЕ ь╖иьЖМ ьШИьХ╜ тАФ ъ╕░ъ░Д ызМыгМ ьЛЬьаРьЧР status=canceled
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events   PaymentEvent[]
}

// ъ▓░ьаЬ┬╖эЩШы╢И ьЭ┤ы▓дэК╕ ъ░РьВм ыбЬъ╖╕. ьЫ╣эЫЕ┬╖ьИШыПЩ эШ╕ь╢Ь ыкиыСР ьЧмъ╕░ьЧР insert.
// rawPayloadыКФ JSON(эЖаьКд ьЭСыЛ╡ ьЫРы│╕). ыжмь╜ШьЛдыжмьЧРьЭ┤ьЕШьЪй.
model PaymentEvent {
  id             String   @id @default(cuid())
  userId         String
  // TeacherSubscription.userId. ъ╡мыПЕ ь╖иьЖМ эЫДьЧРыПД ьЭ┤ыаеьЭА ыВиъ▓иьХ╝ эХШыпАыбЬ FK SetNull.
  subscriptionId String?
  // "charge" | "refund" | "cancel" | "billing_key_issued" | "webhook"
  type           String
  amount         Int      @default(0)
  currency       String   @default("KRW")
  // "pending" | "succeeded" | "failed"
  status         String   @default("pending")
  pgOrderId      String?  @unique
  pgPaymentKey   String?
  rawPayload     Json?
  errorMessage   String?
  createdAt      DateTime @default(now())

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription TeacherSubscription? @relation(fields: [subscriptionId], references: [userId], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subscriptionId])
}

// тФАтФАтФАтФА Canva Connect API token store тФАтФАтФАтФА
// Canva as an IdP тАФ teachers OAuth into their Canva account so we can call
// Canva's REST API on their behalf (e.g. list designs, export PDF). Storing
// tokens in DB (not in-memory Map) so Vercel Function cold starts don't
// silently log the teacher out between requests.
//
// `pkceVerifier` holds the transient verifier during the authorize тЖТ callback
// round-trip. It's cleared on successful exchangeCode. For a long-idle user
// whose refresh token has also expired we simply require re-authorize.
model CanvaConnectAccount {
  userId       String    @id
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  pkceVerifier String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// тФАтФАтФАтФА Classroom system тФАтФАтФАтФА

model Classroom {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // 6-char alphanumeric, teacher shares this
  teacherId String
  createdAt DateTime @default(now())

  teacher         User                      @relation(fields: [teacherId], references: [id])
  students        Student[]
  boards          Board[]                   @relation("ClassroomBoards")
  plantAllows     ClassroomPlantAllow[]
  inviteCodes     ClassInviteCode[]
  assessments     AssessmentTemplate[]
  roleAssignments ClassroomRoleAssignment[]
  currency        ClassroomCurrency?
  studentAccounts StudentAccount[]
  storeItems      StoreItem[]
  rolePermissions ClassroomRolePermission[]
  djPlayEvents    DjPlayEvent[]
  aiFeedbacks     AiFeedback[]

  @@index([teacherId])
  @@index([code])
}

model Student {
  id             String   @id @default(cuid())
  classroomId    String
  number         Int? // ь╢ЬьДЭы▓ИэШ╕
  name           String
  qrToken        String   @unique // UUID тАФ encoded in QR
  textCode       String   @unique // 6-char alphanumeric тАФ manual entry fallback
  sessionVersion Int      @default(1)
  createdAt      DateTime @default(now())

  classroom             Classroom                 @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  quizPlayers           QuizPlayer[]
  studentPlants         StudentPlant[]
  assets                StudentAsset[]
  breakoutMemberships   BreakoutMembership[]
  parents               ParentChildLink[]
  parentInvites         ParentInviteCode[]
  cardsAuthored         Card[]                    @relation("StudentCardAuthor")
  oauthAuthCodes        OAuthAuthCode[]
  oauthAccessTokens     OAuthAccessToken[]
  oauthRefreshTokens    OAuthRefreshToken[]
  canvaAppLink          CanvaAppLink?
  assignmentSlots       AssignmentSlot[]          @relation("StudentAssignmentSlots")
  cardAuthors           CardAuthor[]              @relation("StudentCardAuthors")
  assessmentSubmissions AssessmentSubmission[]
  roleAssignments       ClassroomRoleAssignment[]
  account               StudentAccount?
  vibeProjectsAuthored  VibeProject[]             @relation("VibeProjectAuthor")
  vibeSessions          VibeSession[]             @relation("VibeSessionAuthor")
  vibeReviews           VibeReview[]              @relation("VibeReviewer")
  vibePlaySessions      VibePlaySession[]         @relation("VibePlayer")
  boardResponses        BoardResponse[]           @relation("StudentBoardResponses")
  aiFeedbacks           AiFeedback[]
  showcaseEntries       ShowcaseEntry[]
  // card-comments-likes (2026-04-26)
  cardComments          CardComment[]             @relation("StudentCardComments")
  cardLikes             CardLike[]                @relation("StudentCardLikes")
  agentSessions         AgentSession[]

  @@unique([classroomId, number])
  @@index([classroomId])
  @@index([qrToken])
  @@index([textCode])
}

// тФАтФАтФАтФА AI эПЙьЦ┤ (2026-04-24) тФАтФАтФАтФА
// ъ╡РьВмъ░А эХЩьГЭы│Д┬╖ыЛиьЫРы│Д┬╖эПЙъ░АэХныкйы│ДыбЬ AI ъ░А ьГЭьД▒эХЬ эПЙьЦ┤(ьГЭъ╕░ы╢А эЖд ым╕ьЮе)ьЭД ьаАьЮе.
// ьШБьЖН ьаХь▒Е B: ъ╡РьВмъ░А ыкиыЛмьЧРьДЬ "ы│┤ыВ┤ъ╕░" ы▓ДэК╝ьЭД ыИДые╕ ьЛЬьаРьЧРызМ row ьГЭьД▒/UPDATE.
// ъ░ЩьЭА (эХЩьГЭ, ъ│╝ыкй, ыЛиьЫР, эПЙъ░АэХныкй) ьб░эХй ьЮмьГЭьД▒ ьЛЬ ыПЩьЭ╝ row UPSERT (ыНоьЦ┤ьУ░ъ╕░).
// ьЩ╕ы╢А ь╗┤эМиыЛИьЦ╕ ьХ▒ Aura ъ░А GET /api/external/feedbacks ыбЬ эТАэХ┤ ьвЕэХй.
// эХЩьГЭ/эХЩы╢Аыки ыЕ╕ь╢Ь X тАФ ъ╡РьВм ьаДьЪй.
model AiFeedback {
  id          String   @id @default(cuid())
  teacherId   String
  classroomId String
  studentId   String
  subject     String   // v1 'art', эЦеэЫД ыЛдъ│╝ыкй эЩХьЮе ыМАы╣Д free string
  unit        String
  criterion   String
  comment     String   @db.Text
  model       String   // ьВмьЪйыРЬ LLM model id (ъ░РьВм┬╖ыФФы▓Дъ╣ЕьЪй)
  sentAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   User      @relation("TeacherAiFeedbacks", fields: [teacherId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, unit, criterion])
  @@index([classroomId, updatedAt])
  @@index([teacherId, updatedAt])
}

// layout: "freeform" | "grid" | "stream" | "columns" | "assignment" | "quiz" | "plant-roadmap" | "event-signup" | "drawing" | "breakout" | "vibe-arcade" | "vibe-gallery"
// (validated in app via zod)
model Board {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  layout      String   @default("freeform")
  description String   @default("")
  classroomId String?
  createdAt   DateTime @default(now())
  // classroom-boards-tab "ЁЯЯв ьГИ эЩЬыПЩ" ы░░ьзАъ░А ьЛдьаЬ эЩЬыПЩьЭД ы░ШьШБэХШыПДыбЭ ь╢Фъ░А.
  // @updatedAtьЭА Board эЦЙ ьЮРь▓┤ъ░А update ыРа ыХМызМ ьЮРыПЩ bumpыРШыпАыбЬ, ь╣┤ыУЬ/ьД╣ьЕШ
  // mutation ыЭ╝ьЪ░эК╕ьЧРьДЬ ы╢Аыки board.update({updatedAt: new Date()})ыбЬ ыкЕьЛЬьаБ
  // touch эХЬыЛд (src/app/api/cards/**, src/app/api/sections/**).
  updatedAt   DateTime @updatedAt

  // тФАтФА Event-signup (ES-1) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  // Public link access. "classroom" = NextAuth or classroom-scoped only.
  // "public-link" = anyone with accessToken in URL can view the signup form.
  accessMode          String    @default("classroom")
  accessToken         String?   @unique
  eventPosterUrl      String?
  applicationStart    DateTime?
  applicationEnd      DateTime?
  eventStart          DateTime?
  eventEnd            DateTime?
  venue               String?
  maxSelections       Int?
  videoPolicy         String    @default("optional") // "none" | "optional" | "required"
  videoProviders      String    @default("youtube") // csv
  maxVideoDurationSec Int?
  maxVideoSizeMb      Int?
  allowTeam           Boolean   @default(false)
  maxTeamSize         Int?
  customQuestions     String    @default("[]") // JSON-encoded question[]
  announceMode        String    @default("private") // "public-list" | "private-search" | "private"
  requireApproval     Boolean   @default(false)
  askName             Boolean   @default(true)
  askGradeClass       Boolean   @default(true)
  askStudentNumber    Boolean   @default(true)
  askContact          Boolean   @default(false)

  // тФАтФА Assignment board (AB-1) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  assignmentGuideText String?   @default("")
  assignmentAllowLate Boolean   @default(true)
  assignmentDeadline  DateTime?

  // тФАтФА Question board (QB-1, 2026-04-23) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  // layout="question-board" ьаДьЪй. ъ╡РьВмъ░А ьг╝ьаЬые╝ ьДдьаХэХШъ│а эХЩьГЭыУдьЭ┤ ьЮРьЬа эЕНьКдэК╕
  // ьЭСыЛ╡ьЭД ьШмыж░ыЛд. questionVizMode ыКФ ъ╡РьВмъ░А ьДаэГЭэХЬ ьЛЬъ░БэЩФ ыкиыУЬ.
  questionPrompt    String?
  questionVizMode   String     @default("word-cloud")

  // тФАтФА card-comments-likes (2026-04-26) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  // ы│┤ыУЬ ыЛиьЬД эЖаъ╕А: ь╣┤ыУЬ ьЮСьД▒ьЮР/ыМУъ╕А ьЮСьД▒ьЮР эСЬъ╕░ые╝ ьЭ╡ыкЕ("ьЭ╡ыкЕ") ьЬ╝ыбЬ ызИьКдэВ╣.
  // ьвЛьХДьЪФ ь╣┤ьЪ┤эК╕ыКФ ьШБэЦе ьЧЖьЭМ (ыИДъ░А ыИМыаАыКФьзАыКФ ьЦ┤ь░иэФ╝ ы╣Дъ│╡ъ░Ь).
  anonymousAuthor   Boolean    @default(false)

  classroom          Classroom?          @relation("ClassroomBoards", fields: [classroomId], references: [id], onDelete: SetNull)
  members            BoardMember[]
  cards              Card[]
  sections           Section[]
  submissions        Submission[]
  quizzes            Quiz[]
  studentPlants      StudentPlant[]
  breakoutAssignment BreakoutAssignment?
  assignmentSlots    AssignmentSlot[]
  vibeArcadeConfig   VibeArcadeConfig?
  vibeProjects       VibeProject[]
  djPlayEvents       DjPlayEvent[]
  responses          BoardResponse[]
}

// Question Board ьЭСыЛ╡ (QB-1, 2026-04-23).
// эХШыВШьЭШ Board(layout=question-board) ьЧР N ъ░Ь ьЭСыЛ╡. эХЩьГЭ ыШРыКФ ъ╡РьВмъ░А ьЮСьД▒.
// Board ьВньаЬ ьЛЬ cascade, Student/User ьВньаЬ ьЛЬ ьЭСыЛ╡ьЭА ыВиьзАызМ authorship эХ┤ьзА.
model BoardResponse {
  id        String   @id @default(cuid())
  boardId   String
  studentId String?
  userId    String?
  text      String
  createdAt DateTime @default(now())

  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student Student? @relation("StudentBoardResponses", fields: [studentId], references: [id], onDelete: SetNull)
  user    User?    @relation("UserBoardResponses", fields: [userId], references: [id], onDelete: SetNull)

  @@index([boardId, createdAt])
  @@index([boardId, studentId])
}

// Columns/KanbanьЪй ьД╣ьЕШ (grid/streamьЧРьДа ьВмьЪй ьХИ эХи)
model Section {
  id          String  @id @default(cuid())
  boardId     String
  title       String
  order       Int     @default(0)
  // shared-column-sort (2026-04-20): ъ╡РьВмъ░А ьДаэГЭэХЬ ь╣╝ыЯ╝ы│Д ьаХыам ыкиыУЬъ░А
  // эХЩьГЭ эЩФый┤ьЧРыПД ъ│╡ьЬаыРШыПДыбЭ ьДЬы▓ДьЧР ьаАьЮе. "manual" | "newest" | "oldest"
  // | "title". null тЖТ эБ┤ыЭ╝ьЭ┤ьЦ╕эК╕ъ░А "manual"ыбЬ ь▓Шыжм(ъ╕░ьб┤ эЦЙ эХШьЬДэШ╕эЩШ).
  sortMode    String?
  // Breakout view (T0-тСа): teacher-rotatable access token.
  // null = no public share link. When set, anyone with the token can view the
  // section-isolated Breakout route. Rotating replaces the value, invalidating
  // previously distributed links. See src/lib/rbac.ts#viewSection.
  accessToken String? @unique

  board               Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards               Card[]               @relation("SectionCards")
  breakoutMemberships BreakoutMembership[]
  missions            Mission[]

  @@index([boardId])
}

// RBAC core: one row per (board, user).
// role: "owner" | "editor" | "viewer" (validated in app via zod)
model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model Card {
  id                 String   @id @default(cuid())
  boardId            String
  sectionId          String?
  authorId           String
  title              String
  content            String
  color              String?
  imageUrl           String?
  // 160├Ч120 WebP thumbnail generated from imageUrl on assignment submit
  // (AC-12). Populated by resizeToWebPThumbUrl тЖТ blob. Falls back to
  // imageUrl in slotRowToDTO when null so legacy rows keep working.
  thumbUrl           String?
  linkUrl            String?
  linkTitle          String?
  linkDesc           String?
  linkImage          String?
  videoUrl           String?
  // card-file-attachment (2026-04-20): ьЭ╝ы░Ш ым╕ьДЬ ь▓иы╢А(PDF/DOCX/XLSX/PPTX/HWP
  // /TXT/ZIP). fileNameьЭА ьЫРы│╕ эММьЭ╝ ьЭ┤ыжД(ьВмьЪйьЮР ыЕ╕ь╢Ь), fileSizeыКФ byte,
  // fileMimeTypeьЭА ьДЬы▓Д ъ▓АьжЭыРЬ MIME. 4ъ░Ь ыкиыСР null тЖТ эММьЭ╝ ь▓иы╢А ьЧЖьЭМ.
  fileUrl            String?
  fileName           String?
  fileSize           Int?
  fileMimeType       String?
  // Student author (when the card was published from the Canva Content
  // Publisher app while the student was logged into Aura). Makes the card
  // a first-class child artifact тАФ parent viewer filters on this FK to show
  // "ыВ┤ ьЮРыЕАьЭШ ь╣┤ыУЬ", and future reporting / ownership logic keys off here.
  studentAuthorId    String?
  // Denormalized display label (= student.name) captured at publish time so
  // the board UI can render "ьЮСьД▒: ъ░АьШи" without joining Student.
  externalAuthorName String?
  // Canva design identifier when the card was published from the Canva
  // Content Publisher app (or a pasted Canva design URL with successful
  // resolve). Enables CanvaEmbedSlot's thumbnail+live toggle UX.
  canvaDesignId      String?
  x                  Float    @default(0)
  y                  Float    @default(0)
  width              Float    @default(240)
  height             Float    @default(160)
  order              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // DJ queue status (layout="dj-queue"ызМ ьВмьЪй). null = ы╣Д-эБР ь╣┤ыУЬ.
  // "pending" | "approved" | "played" | "rejected"
  queueStatus String?

  board            Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  section          Section?          @relation("SectionCards", fields: [sectionId], references: [id], onDelete: SetNull)
  author           User              @relation(fields: [authorId], references: [id])
  studentAuthor    Student?          @relation("StudentCardAuthor", fields: [studentAuthorId], references: [id], onDelete: SetNull)
  assetAttachments AssetAttachment[] @relation("CardAssetAttachments")
  assignmentSlot   AssignmentSlot?   @relation("AssignmentSlotCard")
  authors          CardAuthor[]
  attachments      CardAttachment[]  @relation("CardAttachments")
  showcaseEntries  ShowcaseEntry[]
  comments         CardComment[]
  likes            CardLike[]

  @@index([boardId])
  @@index([sectionId])
  @@index([authorId])
  @@index([studentAuthorId])
}

// card-comments-likes (2026-04-26): ь╣┤ыУЬы│Д ыМУъ╕А + ьвЛьХДьЪФ. ьЮСьД▒ьЮР/ьвЛьХДьЪФ ыИДые╕
// ьВмыЮМьЭА ъ╡РьВм(User) ыШРыКФ эХЩьГЭ(Student) тАФ ыСР ыкиыН╕ьЭД ы│ДыПД nullable FK ыбЬ ы│┤ьЬа,
// dual @@unique ыбЬ ьдСы│╡ ы░йьзА (Postgres NULL distinct ьЭШып╕ьГБ эХЬьк╜ьЭ┤ null ьЭ╕
// эЦЙьЭА unique ъ▓АьВмьЧРьДЬ ьаЬьЩ╕ыРи тЖТ ъ╡РьВм/эХЩьГЭ ьвЛьХДьЪФ 1эЪМьФй enforced).

enum CommentAuthorKind {
  teacher
  student
}

model CardComment {
  id              String            @id @default(cuid())
  cardId          String
  authorKind      CommentAuthorKind
  authorUserId    String? // teacher
  authorStudentId String? // student
  content         String
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?

  card          Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorUser    User?    @relation("UserCardComments", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorStudent Student? @relation("StudentCardComments", fields: [authorStudentId], references: [id], onDelete: SetNull)

  @@index([cardId, createdAt])
  @@index([authorUserId])
  @@index([authorStudentId])
}

model CardLike {
  id             String            @id @default(cuid())
  cardId         String
  likerKind      CommentAuthorKind
  likerUserId    String? // teacher
  likerStudentId String? // student
  createdAt      DateTime          @default(now())

  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  likerUser    User?    @relation("UserCardLikes", fields: [likerUserId], references: [id], onDelete: Cascade)
  likerStudent Student? @relation("StudentCardLikes", fields: [likerStudentId], references: [id], onDelete: Cascade)

  @@unique([cardId, likerUserId])
  @@unique([cardId, likerStudentId])
  @@index([cardId])
}

// student-portfolio (2026-04-26): эХЩьГЭьЭ┤ ьЮРъ╕░ ь╣┤ыУЬые╝ эХЩъ╕Й ыйФьЭ╕эЩФый┤ ьЮРыЮСэХ┤ьЪФ
// ьШБьЧньЧР ыЭДьЪ╕ьзА ьШ╡эК╕ьЭ╕ эЖаъ╕А. эХЬ эХЩьГЭ эХЬ ь╣┤ыУЬ 1ьКмыбп(@@unique). эХЩьГЭыЛ╣
// ьЮРыЮСэХ┤ьЪФ эХЬыПД(эШДьЮм N=3)ыКФ application-level COUNT эК╕ыЮЬьЮньЕШьЬ╝ыбЬ enforce.
// classroomId ыКФ эХЩъ╕Й dashboard highlight ь┐╝ыжм ъ░АьЖН denorm тАФ card.board.
// classroomId ьЩА эХньГБ ьЭ╝ь╣Ш (эК╕ыжмъ▒░ ьЧЖьЭ┤ application ыЛиьЧРьДЬ ьУ░ъ╕░).
model ShowcaseEntry {
  id          String   @id @default(cuid())
  cardId      String
  studentId   String
  classroomId String
  createdAt   DateTime @default(now())

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([cardId, studentId])
  @@index([studentId])
  @@index([classroomId, createdAt])
}

// multi-attachment (2026-04-20): ь╣┤ыУЬ 1ъ░ЬьЧР ьЭ┤ып╕ьзА┬╖ыПЩьШБьГБ┬╖эММьЭ╝ ьЧмыЯм ъ░Ьые╝
// ы╢ЩьЭ╝ ьИШ ьЮИыКФ ьаХъ╖ЬэЩФ эЕМьЭ┤ы╕Ф. `kind`ыКФ "image"|"video"|"file". ыаИъ▒░ьЛЬ
// Card.imageUrl/videoUrl/fileUrl ыЛиьЭ╝ эХДыУЬыКФ ы│Дъ░ЬыбЬ ъ│ДьЖН ьб┤ьЮмэХШый░,
// attachments ы░░ьЧ┤ьЭ┤ ы╣ДьЦ┤ьЮИыКФ ь╣┤ыУЬьЧР эХЬэХ┤ ыаМыНФ fallbackьЬ╝ыбЬ ьВмьЪйыРи.
model CardAttachment {
  id         String   @id @default(cuid())
  cardId     String
  kind       String   // "image" | "video" | "file"
  url        String
  fileName   String?
  fileSize   Int?
  mimeType   String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  card       Card     @relation("CardAttachments", fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model Submission {
  id        String   @id @default(cuid())
  boardId   String
  userId    String? // nullable for public event-signup submissions (ES-1)
  content   String   @default("")
  linkUrl   String?
  fileUrl   String?
  // status (event-signup adds): "pending_approval" | "submitted" | "approved" | "rejected"
  // status (assignment keeps): "submitted" | "reviewed" | "returned"
  status    String   @default("submitted")
  feedback  String?
  grade     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // тФАтФА Event-signup applicant fields (ES-1) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  submitToken      String? @unique // public self-auth for /my page
  applicantName    String?
  applicantGrade   Int?
  applicantClass   Int?
  applicantNumber  Int?
  applicantContact String?
  ipHash           String?
  teamName         String?
  teamMembers      String  @default("[]") // JSON тАФ {name,grade,class,number}[]
  answers          String  @default("{}") // JSON тАФ {questionId: value}
  videoUrl         String?
  videoProvider    String? // "youtube" | "cfstream"
  videoId          String?
  videoThumbnail   String?
  scoreAvg         Float?

  // тФАтФА Assignment-slot linkage (AB-1) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
  // Nullable for backward-compat with event-signup submissions that never had
  // a slot. When present, @unique pins one Submission to one slot so student
  // overwrites happen in-place (no history тАФ decisions Q2).
  assignmentSlotId String?         @unique
  assignmentSlot   AssignmentSlot? @relation(fields: [assignmentSlotId], references: [id], onDelete: SetNull)

  board   Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User?              @relation(fields: [userId], references: [id])
  reviews SubmissionReview[]

  @@index([boardId])
  @@index([userId])
  @@index([boardId, status])
  @@index([ipHash, createdAt])
}

// тФАтФАтФАтФА Assignment-board (AB-1) тФАтФАтФАтФА
// One row per (boardId, studentId) captured at board creation time. v1 hard-
// caps count тЙд 30 (Galaxy Tab S6 Lite perf budget). slotNumber is a snapshot
// of Student.number at creation; Q6 decision тАФ number changes don't propagate.
model AssignmentSlot {
  id               String    @id @default(cuid())
  boardId          String
  studentId        String
  slotNumber       Int
  cardId           String    @unique
  // submissionStatus: "assigned"|"submitted"|"viewed"|"returned"|"reviewed"|"orphaned"
  submissionStatus String    @default("assigned")
  // gradingStatus: "not_graded"|"graded"|"released"
  gradingStatus    String    @default("not_graded")
  grade            String?
  viewedAt         DateTime?
  returnedAt       DateTime?
  returnReason     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student    Student     @relation("StudentAssignmentSlots", fields: [studentId], references: [id], onDelete: Restrict)
  card       Card        @relation("AssignmentSlotCard", fields: [cardId], references: [id], onDelete: Restrict)
  submission Submission?

  @@unique([boardId, studentId])
  @@unique([boardId, slotNumber])
  @@index([studentId])
}

// тФАтФА Event-signup reviews (ES-1, ES-9) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
model SubmissionReview {
  id           String   @id @default(cuid())
  submissionId String
  reviewerId   String
  score        Int
  comment      String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation(fields: [reviewerId], references: [id])

  @@unique([submissionId, reviewerId])
  @@index([submissionId])
  @@index([reviewerId])
}

// тФАтФАтФАтФА Quiz system тФАтФАтФАтФА

model Quiz {
  id           String   @id @default(cuid())
  boardId      String
  title        String   @default("")
  sourceFile   String? // uploaded PDF/PPT filename
  sourceText   String? // extracted text (for reference)
  roomCode     String   @unique // 6-digit code for students to join
  status       String   @default("waiting") // "waiting" | "active" | "finished"
  currentQ     Int      @default(-1) // index of current question (-1 = not started)
  difficulty   String? // "easy" | "medium" | "hard" (quiz-extensions B2)
  parentQuizId String? // clone source Quiz.id тАФ no FK so source delete is allowed (B4)
  createdAt    DateTime @default(now())

  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  players   QuizPlayer[]

  @@index([boardId])
  @@index([roomCode])
  @@index([parentQuizId])
}

model QuizQuestion {
  id        String @id @default(cuid())
  quizId    String
  order     Int    @default(0)
  question  String
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  answer    String // "A" | "B" | "C" | "D"
  timeLimit Int    @default(20) // seconds

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
}

model QuizPlayer {
  id        String   @id @default(cuid())
  quizId    String
  studentId String?
  nickname  String
  score     Int      @default(0)
  joinedAt  DateTime @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student?     @relation(fields: [studentId], references: [id])
  answers QuizAnswer[]

  @@unique([quizId, studentId])
  @@index([quizId])
  @@index([studentId])
}

model QuizAnswer {
  id         String   @id @default(cuid())
  questionId String
  playerId   String
  selected   String // "A" | "B" | "C" | "D"
  correct    Boolean
  timeMs     Int      @default(0) // answer time in ms
  createdAt  DateTime @default(now())

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player   QuizPlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([questionId, playerId])
  @@index([questionId])
  @@index([playerId])
}

// тФАтФАтФАтФА Plant Journal (PJ-1 ~ PJ-6) тФАтФАтФАтФА

model PlantSpecies {
  id         String   @id @default(cuid())
  key        String   @unique // "tomato", "strawberry" тАФ program identifier
  nameKo     String
  emoji      String
  difficulty String   @default("easy") // "easy" | "medium" | "hard"
  season     String   @default("spring") // "spring" | "summer" | "fall" | "winter" | "all"
  notes      String   @default("")
  createdAt  DateTime @default(now())

  stages        PlantStage[]
  allows        ClassroomPlantAllow[]
  studentPlants StudentPlant[]
}

model PlantStage {
  id                String @id @default(cuid())
  speciesId         String
  order             Int
  key               String
  nameKo            String
  description       String @default("")
  icon              String
  observationPoints String // JSON-encoded string[]

  species      PlantSpecies       @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  currentFor   StudentPlant[]     @relation("StudentPlantCurrentStage")
  observations PlantObservation[]

  @@unique([speciesId, order])
  @@index([speciesId])
}

model ClassroomPlantAllow {
  id          String   @id @default(cuid())
  classroomId String
  speciesId   String
  createdAt   DateTime @default(now())

  classroom Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  species   PlantSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([classroomId, speciesId])
  @@index([classroomId])
  @@index([speciesId])
}

model StudentPlant {
  id             String   @id @default(cuid())
  boardId        String
  studentId      String
  speciesId      String
  nickname       String
  currentStageId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  board        Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  species      PlantSpecies       @relation(fields: [speciesId], references: [id])
  currentStage PlantStage         @relation("StudentPlantCurrentStage", fields: [currentStageId], references: [id])
  observations PlantObservation[]

  @@unique([boardId, studentId])
  @@index([boardId])
  @@index([studentId])
  @@index([speciesId])
  @@index([currentStageId])
}

model PlantObservation {
  id             String   @id @default(cuid())
  studentPlantId String
  stageId        String
  memo           String   @default("")
  noPhotoReason  String?
  observedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studentPlant     StudentPlant            @relation(fields: [studentPlantId], references: [id], onDelete: Cascade)
  stage            PlantStage              @relation(fields: [stageId], references: [id])
  images           PlantObservationImage[]
  assetAttachments AssetAttachment[]       @relation("PlantObservationAssetAttachments")

  @@index([studentPlantId])
  @@index([stageId])
  @@index([studentPlantId, stageId])
}

model PlantObservationImage {
  id            String   @id @default(cuid())
  observationId String
  url           String
  thumbnailUrl  String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  observation PlantObservation @relation(fields: [observationId], references: [id], onDelete: Cascade)

  @@index([observationId])
}

// тФАтФАтФАтФА Drawpile student-asset library (partial scope тАФ schema + stub) тФАтФАтФАтФА
// StudentAsset = a student-owned image (uploaded or produced by Drawpile).
// classroomId is denormalized for fast classroom-scoped gallery scans.
// source: "upload" (current path) | "drawpile" (set later when Drawpile fork
// posts back via postMessage bridge тАФ see docs/drawpile-protocol.md).
model StudentAsset {
  id              String   @id @default(cuid())
  studentId       String
  classroomId     String
  title           String   @default("")
  fileUrl         String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  format          String   @default("image/png")
  sizeBytes       Int      @default(0)
  isSharedToClass Boolean  @default(false)
  source          String   @default("upload")
  drawpileFileId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments AssetAttachment[]

  @@index([studentId])
  @@index([classroomId])
  @@index([classroomId, isSharedToClass])
}

// CardAuthor = N:N join row between Card and Student, with a denormalised
// displayName so author names survive student rename/soft-delete. Order
// enforces a stable primary author (order=0) which Card.studentAuthorId +
// Card.externalAuthorName mirror for backward-compatibility. See
// tasks/2026-04-15-card-author-multi/phase3/design_doc.md ┬з1.
model CardAuthor {
  id          String   @id @default(cuid())
  cardId      String
  studentId   String?
  displayName String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  card    Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student Student? @relation("StudentCardAuthors", fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([cardId, studentId])
  @@index([cardId, order])
  @@index([studentId])
}

// AssetAttachment = join row linking a StudentAsset to a Card or
// PlantObservation. Exactly one of (cardId, observationId) is expected to be
// set at attach time. Both nullable to keep Prisma relation checks simple.
model AssetAttachment {
  id            String   @id @default(cuid())
  assetId       String
  cardId        String?
  observationId String?
  createdAt     DateTime @default(now())

  asset       StudentAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  card        Card?             @relation("CardAssetAttachments", fields: [cardId], references: [id], onDelete: Cascade)
  observation PlantObservation? @relation("PlantObservationAssetAttachments", fields: [observationId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([cardId])
  @@index([observationId])
}

// тФАтФАтФАтФА Breakout Room (BR-1 ~ BR-4) тФАтФАтФАтФА
// BreakoutTemplate тАФ reusable group-learning blueprints (8 system + teacher/school custom).
// `structure` JSON schema:
//   { sectionsPerGroup: [{title, role: "group-copy"|"role-expert"|"role-home",
//                         defaultCards?: [{title, content}]}],
//     sharedSections?: [{title, role: "teacher-pool"}] }
// On board creation the structure is deep-cloned into Section rows тЖТ template
// edits never retroactively affect existing boards (decisions Q6).
model BreakoutTemplate {
  id                    String   @id @default(cuid())
  key                   String   @unique
  name                  String
  description           String
  tier                  String   @default("free") // "free" | "pro"
  requiresPro           Boolean  @default(false)
  scope                 String   @default("system") // "system" | "teacher" | "school"
  ownerId               String?
  structure             Json
  recommendedVisibility String   @default("own-only") // "own-only" | "peek-others"
  defaultGroupCount     Int      @default(4)
  defaultGroupCapacity  Int      @default(6)
  createdAt             DateTime @default(now())

  owner       User?                @relation("TemplateOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assignments BreakoutAssignment[]

  @@index([ownerId])
  @@index([scope])
}

// BreakoutAssignment тАФ one per Breakout Board. Tracks deploy + visibility state.
model BreakoutAssignment {
  id                 String   @id @default(cuid())
  boardId            String   @unique
  templateId         String
  deployMode         String   @default("link-fixed") // "link-fixed" | "self-select" | "teacher-assign"
  groupCount         Int      @default(4)
  groupCapacity      Int      @default(6)
  visibilityOverride String? // null = use template.recommendedVisibility
  status             String   @default("active") // "active" | "archived"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  board    Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  template BreakoutTemplate     @relation(fields: [templateId], references: [id])
  members  BreakoutMembership[]

  @@index([templateId])
}

// BreakoutMembership тАФ links a Student to their group Section (role for Jigsaw).
// Foundation does not populate this; BR-5 (deploy modes) writes rows on self-select
// or teacher-assign. `@@unique([sectionId, studentId])` prevents double-membership.
model BreakoutMembership {
  id           String   @id @default(cuid())
  assignmentId String?
  sectionId    String
  studentId    String
  role         String? // "expert" | "home" (Jigsaw) | null
  joinedAt     DateTime @default(now())

  assignment BreakoutAssignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  section    Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  student    Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sectionId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// тФАтФАтФАтФА Parent Viewer Access (PV-1 ~ PV-5) тФАтФАтФАтФА
// Seed 7 (2026-04-12-parent-viewer-access). Read-only viewer for guardians.
// Crockford Base32 6-char invite codes + magic-link auth + 7-day sessions.
// All queries in /parent/* must route through parentScopeMiddleware
// (src/lib/parent-scope.ts). See canva project/plans/parent-viewer-roadmap.md
// for the single-source-of-truth child-scope matrix.

model Parent {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  tier            String    @default("free") // "free" | "pro"
  parentDeletedAt DateTime? // soft delete; 90d anonymization Cron (PV-11)
  anonymizedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  children ParentChildLink[]
  sessions ParentSession[]
  invites  ParentInviteCode[] @relation("IssuedToEmail")
  oauthAccounts ParentOAuthAccount[]

  @@index([email])
  @@index([parentDeletedAt])
}

// parent-redesign (2026-04-26): эХЩы╢Аыки OAuth (Google + Kakao) 1:1 ыздэХС.
// эХЬ Parent ъ░А ьЧмыЯм provider ьЩА link ъ░АыКе (Google ыШРыКФ Kakao ыШРыКФ ыСШ ыЛд).
// (provider, providerAccountId) unique ыбЬ ъ░ЩьЭА OAuth ъ│ДьаХ = ъ░ЩьЭА Parent
// ъ░ХьаЬ. email ыздь╣ньЬ╝ыбЬ ъ╕░ьб┤ ыздьзБызБэБм эХЩы╢АыкиьЩА ьЮРыПЩ link.
model ParentOAuthAccount {
  id                String   @id @default(cuid())
  parentId          String
  provider          String   // "google" | "kakao"
  providerAccountId String
  email             String?
  emailVerified     Boolean  @default(false)
  displayName       String?
  profileImage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([parentId])
  @@index([email])
}

// parent-class-invite-v2 тАФ ParentLinkStatus lifecycle.
//   pending  тЖТ (approve) тЖТ active
//   pending  тЖТ (reject | code_rotated | auto_expired) тЖТ rejected
//   active   тЖТ (teacher_revoked | classroom_deleted | year_end | parent_self_leave) тЖТ revoked
// rejected/revoked are dead-end. See src/lib/parent-link-state.ts for the
// transition validator used by every state-changing endpoint.
enum ParentLinkStatus {
  pending
  active
  rejected
  revoked
}

// UI dropdown for teacher reject action exposes only the first 3 values.
// System-originated reject uses code_rotated | auto_expired | classroom_deleted.
enum ParentRejectedReason {
  wrong_child
  not_parent
  other
  code_rotated
  auto_expired
  classroom_deleted
}

// v1 had 3 revoked reasons; v2 adds 4 more (audit completeness тАФ system
// transitions that originate from pendingтЖТrejected ALSO get a matching
// revokedReason row for downstream reporting).
enum ParentRevokedReason {
  teacher_revoked
  year_end
  parent_self_leave
  rejected_by_teacher
  auto_expired_pending
  code_rotated
  classroom_deleted
}

model ParentChildLink {
  id        String @id @default(cuid())
  parentId  String
  studentId String

  // v2 lifecycle
  status ParentLinkStatus @default(pending)

  // audit тАФ set as status transitions
  requestedAt    DateTime              @default(now())
  approvedAt     DateTime?
  approvedById   String?
  rejectedAt     DateTime?
  rejectedById   String?
  rejectedReason ParentRejectedReason?
  revokedAt      DateTime?
  revokedById    String?
  revokedReason  ParentRevokedReason?

  createdAt DateTime  @default(now())
  deletedAt DateTime? // soft delete (R-07 v1 compat)

  parent     Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("LinkApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User?   @relation("LinkRejectedBy", fields: [rejectedById], references: [id])
  revokedBy  User?   @relation("LinkRevokedBy", fields: [revokedById], references: [id])

  @@unique([parentId, studentId])
  @@index([studentId])
  @@index([parentId])
  @@index([status, requestedAt])
  @@index([deletedAt])
}

// parent-class-invite-v2 тАФ classroom-scoped invite code.
// One active (rotatedAt IS NULL) row per classroom, enforced by a partial
// unique index declared in the migration SQL (Prisma schema doesn't support
// partial uniques directly).
model ClassInviteCode {
  id          String    @id @default(cuid())
  classroomId String
  code        String    @unique
  codeHash    String    @unique
  issuedById  String
  expiresAt   DateTime?
  maxUses     Int?
  rotatedAt   DateTime?
  createdAt   DateTime  @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  issuedBy  User      @relation("ClassInviteIssued", fields: [issuedById], references: [id])

  @@index([classroomId])
  @@index([rotatedAt])
}

model ParentInviteCode {
  id             String    @id @default(cuid())
  studentId      String
  issuedByUserId String // teacher
  code           String    @unique // Crockford Base32 6 chars, normalized upper
  codeHash       String    @unique // sha256 тАФ timing-safe verify + revoke safety
  maxUses        Int       @default(3)
  usesCount      Int       @default(0)
  failedAttempts Int       @default(0) // auto-revoke at 10
  expiresAt      DateTime // +48h from issue
  revokedAt      DateTime?
  boundToEmail   String? // optional binding (teacher knows parent email)
  createdAt      DateTime  @default(now())

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy User    @relation("TeacherInvite", fields: [issuedByUserId], references: [id])
  parent   Parent? @relation("IssuedToEmail", fields: [boundToEmail], references: [email])

  @@index([studentId])
  @@index([expiresAt])
  @@index([boundToEmail])
}

model ParentSession {
  id               String    @id @default(cuid())
  parentId         String
  sessionToken     String    @unique // plaintext cookie value (32-byte base64url)
  tokenHash        String    @unique // sha256 of sessionToken
  userAgent        String?
  ipHash           String?
  expiresAt        DateTime // +7d
  sessionRevokedAt DateTime?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime?

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([sessionToken])
  @@index([tokenHash])
  @@index([expiresAt])
}

// тФАтФАтФАтФА OAuth 2.0 Provider (Seed тАФ oauth2-provider task) тФАтФАтФАтФА
// Aura acts as an OAuth 2.0 Authorization Server for the Canva Content
// Publisher app. Students log into Aura, grant the Canva app `cards:write`
// via an on-device consent screen, then Canva exchanges the auth code for
// an access + refresh token pair that is STUDENT-scoped (not teacher-PAT).
// This replaces bundling a shared teacher PAT in the Canva app binary.
//
// Protocol: RFC 6749 Authorization Code + RFC 7636 PKCE (S256).
// Canva-specific details: https://www.canva.dev/docs/apps/authenticating-users/oauth/
// See src/lib/oauth-server.ts for the runtime helpers.

model OAuthClient {
  id           String   @id // e.g. "canva" тАФ visible client_id
  name         String
  // bcrypt hash of the client secret. Client secrets are rotated by
  // regenerating this row; no plaintext is kept.
  secretHash   String
  // JSON-encoded array of absolute redirect URIs the client is allowed to
  // receive authorization codes at. Canva registers exactly one per app.
  redirectUris String
  // JSON-encoded array of scope strings (e.g. ["cards:write"]). Authorize
  // requests are rejected if they request a scope not in this list.
  scopes       String
  pkceRequired Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  authCodes     OAuthAuthCode[]
  accessTokens  OAuthAccessToken[]
  refreshTokens OAuthRefreshToken[]
}

model OAuthAuthCode {
  // 40-char base64url random тАФ surfaced as `code` query param to client.
  // One-shot: consumedAt is set on the first /oauth/token exchange. Re-use
  // triggers invalidation of the linked access/refresh tokens per RFC 6749.
  //
  // Subject = student (Canva pairing) OR user (Aura companion teacher OAuth).
  // CHECK ьаЬьХ╜: ьаХэЩХэЮИ эХШыВШызМ NOT NULL. ызИьЭ┤ъ╖╕ыаИьЭ┤ьЕШ 20260424_oauth_teacher_subject.
  code                String    @id
  studentId           String?
  userId              String?
  clientId            String
  redirectUri         String
  scope               String
  codeChallenge       String // PKCE S256 base64url
  codeChallengeMethod String    @default("S256")
  state               String? // opaque, echoed back; stored for audit
  expiresAt           DateTime // +10 min from issuance
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthAuthCodes", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

model OAuthAccessToken {
  // SHA-256 hex of the plaintext token. Plaintext is only ever returned in
  // the token exchange response and never stored.
  tokenHash      String    @id
  // 8-char base62 prefix extracted from plaintext тАФ O(1) lookup index. The
  // plaintext returned is `aurastu_{prefix}_{secret}` (student) or
  // `auratea_{prefix}_{secret}` (teacher).
  tokenPrefix    String    @unique
  studentId      String?
  userId         String?
  clientId       String
  scope          String
  expiresAt      DateTime // +30 days default (student); +1h (teacher)
  revokedAt      DateTime?
  // When this access token was rotated out of a refresh_token grant we keep
  // the id of the new refresh token so audits can trace chains.
  refreshTokenId String?
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthAccessTokens", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@index([studentId])
  @@index([userId])
  @@index([expiresAt])
}

model OAuthRefreshToken {
  tokenHash       String    @id
  tokenPrefix     String    @unique
  studentId       String?
  userId          String?
  clientId        String
  scope           String
  expiresAt       DateTime // +180 days default (student); +30 days (teacher)
  revokedAt       DateTime?
  // Parent refresh token (set when the current token was rotated out of a
  // prior refresh grant). Used to detect refresh-token reuse attacks тАФ if a
  // revoked refresh is presented, we also revoke the chain.
  parentTokenHash String?
  createdAt       DateTime  @default(now())

  student Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserOAuthRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  client  OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@index([studentId])
  @@index([userId])
  @@index([expiresAt])
}

// Maps a Canva user (per the Canva Apps SDK's getCanvaUserToken JWT `sub`
// claim) to one of our Student rows. Populated during OAuth consent when
// the student authorizes the Canva app. Backend uses this table to resolve
// Canva JWT Bearer tokens to an Aura-board student for external/* routes.
model CanvaAppLink {
  canvaUserId String   @id
  studentId   String   @unique
  scope       String   @default("cards:write")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// тФАтФАтФАтФА Assessment (performance-assessment-autograde MVP-0) тФАтФАтФАтФА

model AssessmentTemplate {
  id          String   @id @default(cuid())
  classroomId String
  boardId     String? // Board(layout="assessment") shell link. nullable тАФ template can exist without a board.
  title       String
  durationMin Int      @default(30)
  createdById String // teacher User.id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  @@index([classroomId])
  @@index([boardId])
