model ErrorLog {
  id String @id @default(cuid())

  userId String?

  userEmail String?

  feature String

  path String?

  status Int?

  message String

  stack String?

  metadata Json?

  // "production" is written only by the deployed Vercel production runtime.
  // Existing rows are intentionally "unknown" so local history is never
  // mistaken for a production incident.
  environment String @default("unknown")

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([feature, createdAt])
  @@index([userEmail, createdAt])
  @@index([status, createdAt])
  @@index([environment, createdAt])
}

// Operational activity is deliberately separate from AuditEvent. AuditEvent
// records sensitive or administrative actions; this table powers the admin
// dashboard's factual, board-scoped activity feed.
model BoardActivityEvent {
  id String @id @default(cuid())

  boardId String

  action String

  actorType String @default("system")

  actorId String?

  metadata Json?

  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([boardId, createdAt])
  @@index([actorType, createdAt])
}

