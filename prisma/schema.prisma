// Aura-board ??Prisma schema

// DB: SQLite for local dev. To switch to Postgres:

//   1) change provider to "postgresql"

//   2) change DATABASE_URL to postgres://??//   3) run `prisma db push --force-reset`

// Avoid SQLite-specific types (@db.*) so the schema stays portable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")

  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(cuid())

  email String @unique

  name String

  image String?

  appBackgroundUrl String?

  emailVerified DateTime?

  createdAt DateTime @default(now())

  memberships BoardMember[]

  cards Card[]

  submissions Submission[]

  reviews SubmissionReview[]

  accounts Account[]

  sessions Session[]

  classrooms Classroom[]

  templatesOwned BreakoutTemplate[] @relation("TemplateOwner")

  issuedParentInvites ParentInviteCode[] @relation("TeacherInvite")

  canvaConnect CanvaConnectAccount?

  // parent-class-invite-v2 ??issued codes + audit FKs into ParentChildLink

  classInvitesIssued ClassInviteCode[] @relation("ClassInviteIssued")

  approvedParentLinks ParentChildLink[] @relation("LinkApprovedBy")

  rejectedParentLinks ParentChildLink[] @relation("LinkRejectedBy")

  revokedParentLinks ParentChildLink[] @relation("LinkRevokedBy")

  // dj-board-queue ??teacher audit for role assignments

  roleAssignmentsGranted ClassroomRoleAssignment[] @relation("ClassroomRoleAssignedBy")

  // Teacher's own LLM API key (vibe-arcade + future AI features)

  llmKey TeacherLlmKey?

  // Billing (Toss Payments ?嶺???껊눇?용맪?????Seed 14 scaffold, 2026-04-22)

  subscription TeacherSubscription?

  paymentEvents PaymentEvent[]

  boardResponses BoardResponse[] @relation("UserBoardResponses")

  kordleAttempts KordleAttempt[] @relation("TeacherKordleAttempts")

  // AI back-relation for AiFeedback (2026-04-24)

  aiFeedbacks AiFeedback[] @relation("TeacherAiFeedbacks")

  // Aura evaluation back-relation for CardEvaluation (2026-06-23)

  cardEvaluations CardEvaluation[] @relation("TeacherCardEvaluations")

  // OAuth as subject ??Aura companion teacher OAuth (2026-04-24)

  oauthAuthCodesAsUser OAuthAuthCode[] @relation("UserOAuthAuthCodes")

  oauthAccessTokensAsUser OAuthAccessToken[] @relation("UserOAuthAccessTokens")

  oauthRefreshTokensAsUser OAuthRefreshToken[] @relation("UserOAuthRefreshTokens")

  // card-comments-likes (2026-04-26)

  cardComments CardComment[] @relation("UserCardComments")

  cardLikes CardLike[] @relation("UserCardLikes")

  commentLikes CardCommentLike[] @relation("UserCardCommentLikes")

  // Classroom check tasks created by this teacher (checker role, 2026-06-28)
  classroomCheckTasks ClassroomCheckTask[] @relation("ClassroomCheckTaskCreatedBy")

  cleaningFindingsReported CleaningFinding[] @relation("CleaningFindingReporterUser")
  shoeFindingsReported     ShoeFinding[]     @relation("ShoeFindingReporterUser")

  // Yellow card + cleaning duty (2026-07-08)
  yellowCardsGivenByUser YellowCard[]   @relation("YellowCardGivenByUser")
  cleaningDutiesAssigned CleaningDuty[] @relation("CleaningDutyAssignedBy")

  // ===== Speed Game (스피드게임, 2026-07-06) =====
  // Teacher-owned word sets. System sets live with userId = NULL; user sets
  // scope to a single teacher (no classroom-level sharing in v1).
  speedGameWordSets SpeedGameWordSet[]

  // Global daily banner moderation/publication.
  dailyBannerReviews      DailyBannerSubmission[]  @relation("DailyBannerReviewedBy")
  dailyBannerPublications DailyBannerPublication[] @relation("DailyBannerPublishedBy")
}

