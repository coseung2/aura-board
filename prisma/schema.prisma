model AssessmentQuestion {
  id         String   @id @default(cuid())
  templateId String
  order      Int
  kind       String // MVP-0 accepts "MCQ" only; future: "SHORT"|"OX"|"NUMERIC"|"ESSAY".
  prompt     String
  // MCQ payload: { choices: [{id, text}], correctChoiceIds: string[] }
  payload    Json
