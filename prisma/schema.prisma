// Vibe-arcade (Seed 13) тАФ эХЩъ╕Й Steam. Board(layout="vibe-arcade") ьаДьЪй.
// enabledыКФ ыЯ░ь╣н эФМыЮШъ╖╕ ьЧнэХа(FeatureFlag эЕМьЭ┤ы╕Ф ьЛаьДд ыМАьЛа ConfigьЧР эЭбьИШ).
// тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА

model VibeArcadeConfig {
  boardId                 String   @id
  enabled                 Boolean  @default(false) // ы│┤ыУЬы│Д ыЯ░ь╣н ъ▓МьЭ┤эК╕
  // "teacher_approval_required"(v1 ъ╕░ы│╕) | "auto_publish" | "hybrid_trusted"(v1.5)
  moderationPolicy        String   @default("teacher_approval_required")
  // эХЩьГЭ 1ьЭ╕ ьЭ╝ьЭ╝ Sonnet эЖаэБ░ ьГБэХЬ(IN+OUT). null = эХЩъ╕Й эТА ъ│╡ьЬаызМ.
  perStudentDailyTokenCap Int?     @default(45000)
  // эХЩъ╕Й ьаДь▓┤ ьЭ╝ьЭ╝ эЖаэБ░ эТА. 0 = vibe-arcade ы╣ДэЩЬьД▒(ъ╕┤ъ╕Й ьаХьзА).
  classroomDailyTokenPool Int      @default(1500000)
  // U-4 эХЩъ╕Й ъ░Д ъ│╡ьЬа (ы░Ш ыВ┤ы╢АызМ v1 ъ╕░ы│╕)
  crossClassroomVisible   Boolean  @default(false)
  // U-2 "named" | "anonymous" | "hidden_to_peer"
  reviewAuthorDisplay     String   @default("named")
  // U-3 "stars_1_5" | "thumbs" | "emoji_5"(v2)
  reviewRatingSystem      String   @default("stars_1_5")
  // F-4 v1ьЭА false ъ│аьаХ
  allowRemix              Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model VibeProject {
  id               String    @id @default(cuid())
  boardId          String
  classroomId      String    // ы╣ДьаХъ╖ЬэЩФ тАФ эХЩъ╕Й ьКдь╜ФэФД ы╣аые╕ ьКдь║Ф
  authorStudentId  String
  title            String
  description      String    @default("") // тЙд500ьЮР
  // Vibe studio 3-tab split (2026-04-21). htmlContentыКФ <body> ы│╕ым╕ызМ ы│┤ъ┤АэХШъ│а
  // cssContent/jsContentыКФ ъ░Бъ░Б <style>/<script>ыбЬ эХйьД▒ыРЬыЛд. ъ╕░ьб┤ ыЛиьЭ╝-HTML ыаИь╜ФыУЬыКФ
  // cssContent="", jsContent=""ыбЬ backfill ыРШый░ ыаМыНФыЯмъ░А ъ╖╕ыМАыбЬ ыПЩьЮС (bodyызМ ьг╝ьЮЕ).
  htmlContent      String    // <body> ы│╕ым╕ тАФ CSP sandbox эЧдыНФ ы╢Аь░й
  cssContent       String    @default("")
  jsContent        String    @default("")
  thumbnailUrl     String?   // ьДЬы▓Д Playwright headless 160├Ч120 WebP
  // ъ│аьаХ эГЬъ╖╕ 5ьвЕ ьдС 1ъ░Ь: "ъ▓МьЮД"|"эА┤ьжИ"|"ьЛЬыом"|"ьХДэК╕"|"ъ╕░эГА" (JSON ы░░ьЧ┤)
  tags             String    @default("[]")
  // "draft"|"pending_review"|"approved"|"rejected"|"flagged"|"hidden"
  moderationStatus String    @default("draft")
  moderationNote   String?   // тЙд300ьЮР
  approvedAt       DateTime?
  approvedById     String?   // Teacher User.id
  rejectedAt       DateTime?
  rejectedById     String?
  playCount        Int       @default(0)
  uniquePlayCount  Int       @default(0)
  reviewCount      Int       @default(0)
  ratingAvg        Float?
  version          Int       @default(1) // ьЮмьаЬь╢Ь ьЛЬ ьжЭъ░А
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  board        Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author       Student           @relation("VibeProjectAuthor", fields: [authorStudentId], references: [id], onDelete: Restrict)
  sessions     VibeSession[]
  reviews      VibeReview[]
  playSessions VibePlaySession[]
  agentSessions AgentSession[]

  @@index([boardId, moderationStatus])
  @@index([classroomId, moderationStatus, createdAt])
  @@index([authorStudentId])
}

model VibeSession {
  id           String    @id @default(cuid())
  projectId    String?   // null = ьХДьзБ эФДыбЬьаЭэК╕ ьаАьЮе ьаД
  // nullable тАФ 7ьЭ╝ ып╕эЩЬьД▒ ьЭ╡ыкЕэЩФ cronьЭ┤ studentId=null ыбЬ ьаДэЩШ (AC-G5).
  studentId    String?
  classroomId  String    // ы╣ДьаХъ╖ЬэЩФ (ь┐╝эД░ ьКдь║Ф). Student ьЭ╡ыкЕэЩФ эЫДьЧРыПД ьЬаьзА.
  messages     Json      // [{role, content, createdAt}]
  tokensIn     Int       @default(0)
  tokensOut   Int       @default(0)
  // "active"|"completed"|"abandoned"|"failed"
  status       String    @default("active")
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  refusalCount Int       @default(0) // Anthropic stop_reason="refusal"

  project VibeProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  student Student?     @relation("VibeSessionAuthor", fields: [studentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([studentId, startedAt])
  @@index([classroomId, startedAt])
}

model VibeReview {
  id                String   @id @default(cuid())
  projectId         String
  reviewerStudentId String
  // 1-5 ы│ДьаР. reviewRatingSystem="thumbs"ый┤ 1 ыШРыКФ 5ызМ эЧИьЪй.
  rating            Int
  comment           String   @default("")
  // "visible"|"hidden_by_teacher"|"flagged"
  moderationStatus  String   @default("visible")
  flagCount         Int      @default(0) // ьЮДъ│Д 3 тЖТ ьЮРыПЩ hidden
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project  VibeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewer Student     @relation("VibeReviewer", fields: [reviewerStudentId], references: [id], onDelete: Cascade)

  @@unique([projectId, reviewerStudentId]) // эХЩьГЭ 1ьЭ╕ 1ыжмы╖░
  @@index([projectId])
  @@index([reviewerStudentId])
}

model VibePlaySession {
  id            String    @id @default(cuid())
  projectId     String
  studentId     String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  completed     Boolean   @default(false) // iframe postMessage "ьЩДыгМ" ьИШьЛа
  reportedScore Int?      // эЖ╡ъ│Д┬╖ыЮнэВ╣ ь░╕ъ│аьЪй (ъ▓МьЮД ыбЬьзБ ьЛаыв░ X)

  project VibeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  student Student     @relation("VibePlayer", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
  @@index([studentId, startedAt])
}

model VibeQuotaLedger {
  id            String   @id @default(cuid())
  classroomId   String
  // Non-null + ьД╝эЛ░ыДм "__CLASSROOM__" тАФ PostgresьЭШ UNIQUE NULL-distinct ыПЩьЮСьЬ╝ыбЬ
  // compound uniqueъ░А ъ╣иьзАыКФ ым╕ьаЬые╝ эФ╝эХЬыЛд. ъ░Т ъ┤АыжмыКФ `lib/vibe-arcade/quota-ledger.ts`.
  studentId     String
