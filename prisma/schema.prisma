  tokensIn      Int      @default(0)
  tokensOut     Int      @default(0)
  sessionsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([classroomId, studentId, date])
  @@index([classroomId, date])
  @@index([studentId, date])
}

// тФАтФА Statistics Class Board тАФ Mission (2026-05-03 statistics-class-board) тФАтФА
// ы╕МыаИьЭ┤эБмьХДьЫГыг╕ ъ╕░ы░Ш эМАы│Д 11ыЛиъ│Д ып╕ьЕШ ьГБэГЬ ъ┤Аыжм.
enum MissionStatus {
  not_started
  in_progress
  pending_approval
  approved
  teacher_working
  completed
}

model Mission {
  id              String        @id @default(cuid())
  sectionId       String
  stepNumber      Int
  status          MissionStatus @default(not_started)
  content         Json          @default("{}")
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  teacherFeedback String?
  version         Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, stepNumber])
  @@index([sectionId, status])
  @@index([sectionId, stepNumber])
}

// тФАтФА DJ Board ьЮмьГЭ ьЭ┤ы▓дэК╕ ыбЬъ╖╕ (2026-04-22 dj-recap) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
// Card.queueStatus='played' ьаДэЩШ ьЛЬ 1ъ▒┤ ъ╕░ыбЭ. Card ьВньаЬыП╝ыПД ьЭ┤ы▓дэК╕ыКФ ыВиьХДьДЬ
// ьЫФызР ыжмь║б ьзСъ│Дъ░А ьХИьаХьаБ. ъ░ЩьЭА ъ│бьЭД ьЮмы│╡ъ╖А эЫД ыЛдьЛЬ ьЮмьГЭэХШый┤ ьЭ┤ы▓дэК╕ 2ъ▒┤.
model DjPlayEvent {
  id            String   @id @default(cuid())
  boardId       String
  classroomId   String
  cardId        String?  // ь╣┤ыУЬ ьВньаЬ ыМАьЭС тАФ nullable + ьИШыПЩ FK ьЧЖьЭ┤ IDызМ ы│┤ьб┤
  title         String
  linkUrl       String?
  linkImage     String?
  videoId       String?  // youtube 11ьЮР id тАФ ъ░ЩьЭА ъ│б ьзСъ│Д join key
  submitterName String?
  submitterId   String?  // Student.id ыШРыКФ User.id (ъ╡РьВм ьЛаь▓н ыМАьЭС)
  submitterKind String?  // "student" | "teacher" | "anon"
  durationSec   Int?     // YouTube oEmbed ьЧРьДЬ ы╜СэЮМ ъ╕╕ьЭ┤(ь┤И), ьЧЖьЬ╝ый┤ null
  playedAt      DateTime @default(now())

  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([boardId, playedAt])
  @@index([classroomId, playedAt])
  @@index([videoId])
}

// тФАтФА Agent Service: эХЩьГЭ ьаДьЪй AI ь▒ДэМЕ ьД╕ьЕШ (2026-05-17) тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА
// ъ░Б эХЩьГЭьЭ┤ ьКдьКдыбЬ ьЧ┤ ьИШ ьЮИыКФ ь▒ДэМЕ ьД╕ьЕШ. VibeSession(ьКмыбп ъ╕░ы░Ш)ъ│╝ ы│Дъ░ЬыбЬ
// arcade(ъ▓МьЮД) / tutor(эХЩьК╡) / code(ь╜ФыФй) / lesson(ьИШьЧЕ) ыкиыУЬые╝ ьзАьЫР.
// ь▒ДэМЕ ъ▓░ъ│╝ыКФ VibeProjectыбЬ ьаАьЮе ъ░АыКе (projectId nullable link).
model AgentSession {
  id           String   @id @default(cuid())
  studentId    String
  classroomId  String   // ы╣ДьаХъ╖ЬэЩФ тАФ classroom-scoped scan
  // "arcade" | "tutor" | "code" | "lesson"
  mode         String   @default("arcade")
  title        String   @default("") // auto-generated from first exchange
  status       String   @default("active") // "active" | "completed" | "abandoned"
  projectId    String?  // VibeProject.id тАФ ьаАьЮе эЫД ызБэБм
  tokenCount   Int      @default(0)
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student  Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  project  VibeProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages AgentMessage[]

  @@index([studentId, status])
  @@index([studentId, createdAt])
  @@index([classroomId, createdAt])
}

model AgentMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // "user" | "assistant" | "system"
  content    String
  tokenCount Int?     // assistant ыйФьЛЬьзАьЭШ эЖаэБ░ ьВмьЪйыЯЙ
  createdAt  DateTime @default(now())

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
